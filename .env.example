# Default placeholders. Build Engine appends plan-required env vars below.

# Postgres connection string (set per-build by Deployer)
DATABASE_URL=

# Better Auth session secret (auto-generated per build; min 32 chars)
BETTER_AUTH_SECRET=

# Better Auth base URL (the app's public origin; set per-build by Deployer)
BETTER_AUTH_URL=

# Google OAuth credentials — every app ships "Continue with Google".
# Supplied by a human at the approval gate, injected at deploy time.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required by plan
# 32-byte hex key for AES-256-GCM encryption of Slack webhook URLs (secret)
ENCRYPTION_KEY=

# Bearer token for POST /api/cron/run-monitors — sent in Authorization header (secret)
CRON_SECRET=

# Path to system Chromium binary installed by playwright install chromium --with-deps (auto-detected if unset) (optional)
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
